    {
      "activities": [],
      "description": "The [[lookup @name lowercase]]{monster} has five heads. Whenever the [[lookup @name lowercase]]{monster} takes 25 damage or more on a single turn, one of its heads dies. The [[lookup @name lowercase]]{monster} dies if all its heads are dead. At the end of each of its turns when it has at least one living head, the [[lookup @name lowercase]]{monster} grows two heads for each of its heads that died since its last turn, unless it has taken Fire damage since its last turn. The [[lookup @name lowercase]]{monster} regains 20 Hit Points when it grows new heads.",
      "kind": "special",
      "legendary_cost": null,
      "name": "Multiple Heads",
      "recharge": null,
      "slug": "multiple-heads",
      "uses_per_day": null
    },
    {
      "activities": [],
      "description": "For each head the [[lookup @name lowercase]]{monster} has beyond one, it gets an extra &amp;Reference[Reaction] that can be used only for &amp;Reference[OpportunityAttacks].",
      "kind": "special",
      "legendary_cost": null,
      "name": "Reactive Heads",
      "recharge": null,
      "slug": "reactive-heads",
      "uses_per_day": null
    }
