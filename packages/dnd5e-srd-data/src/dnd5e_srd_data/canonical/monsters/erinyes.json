    {
      "activities": [],
      "description": "The [[lookup @name lowercase]]{monster} has a magic rope. While bearing it, the [[lookup @name lowercase]]{monster} can use the [[/item .mmEntanglingRope]] action. The rope has AC 20, HP 90, and Immunity to Poison and Psychic damage. The rope turns to dust if reduced to 0 Hit Points, if it is 5+ feet away from the [[lookup @name lowercase]]{monster} for 1 hour or more, or if the [[lookup @name lowercase]]{monster} dies. If the rope is damaged or destroyed, the [[lookup @name lowercase]]{monster} can fully restore it when finishing a Short or Long Rest.",
      "kind": "special",
      "legendary_cost": null,
      "name": "Magic Rope",
      "recharge": null,
      "slug": "magic-rope",
      "uses_per_day": null
    }
