    {
      "activities": [],
      "description": "The [[lookup @name lowercase]]{monster} is magically bound to an amulet. While the [[lookup @name lowercase]]{monster} and its amulet are on the same plane of existence, the amulet's wearer can telepathically call the [[lookup @name lowercase]]{monster} to travel to it, and the [[lookup @name lowercase]]{monster} knows the distance and direction to the amulet. If the [[lookup @name lowercase]]{monster} is within 60 feet of the amulet's wearer, half of any damage the wearer takes (round up) is transferred to the [[lookup @name lowercase]]{monster}.",
      "kind": "special",
      "legendary_cost": null,
      "name": "Bound",
