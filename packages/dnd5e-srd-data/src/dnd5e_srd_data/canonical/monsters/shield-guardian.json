    {
      "activities": [],
      "description": "A spellcaster who wears the [[lookup @name lowercase]]{monster}'s amulet can cause the [[lookup @name lowercase]]{monster} to store one spell of level 4 or lower. To do so, the wearer must cast the spell on the [[lookup @name lowercase]]{monster} while within 5 feet of it. The spell has no effect but is stored within the [[lookup @name lowercase]]{monster}. Any previously stored spell is lost when a new spell is stored. The [[lookup @name lowercase]]{monster} can cast the spell stored with any parameters set by the original caster, requiring no spell components and using the caster's spellcasting ability. The stored spell is then lost.",
      "kind": "special",
      "legendary_cost": null,
      "name": "Spell Storing",
      "recharge": null,
      "slug": "spell-storing",
